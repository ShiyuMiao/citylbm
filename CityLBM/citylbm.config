# CityLBM 配置文件
# 请根据您的环境修改以下配置

[FluidX3D]
# FluidX3D 源码根目录（包含 FluidX3D.sln 或 Makefile）
# Windows 示例：D:\FluidX3D
# Linux/Mac 示例：/home/user/FluidX3D
InstallPath = D:\FluidX3D

[Simulation]
# 默认模拟参数
DefaultTimeSteps = 5000
DefaultSaveInterval = 500
DefaultViscosity = 1.5e-5

[Output]
# 工作目录（用于存储 Case 文件）
# 留空则使用系统临时目录
WorkingDirectory = 

[MSBuild]
# Visual Studio 安装路径（可选，用于自动查找 MSBuild）
# 留空则自动检测
VisualStudioPath = 
